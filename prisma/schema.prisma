generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String         @id
  name               String
  firstName          String?
  lastName           String?
  fullName           String?
  email              String?        @unique
  password           String?
  image              String
  role               Role
  cart               Json           @default("{}")
  walletBalance      Float          @default(0)
  phone              String         @unique
  isEmailVerified    Boolean        @default(false)
  isPhoneVerified    Boolean        @default(false)
  bankName           String?
  accountNumber      String?
  accountName        String?
  accountStatus      String         @default("pending")
  status             String         @default("active")
  ninDocument        String?
  cacDocument        String?
  businessName       String?
  businessType       String?
  isDirectorVerified Boolean        @default(false)
  verificationNotes  String?
  verificationCode   String?
  verifiedAt         DateTime?
  identityToken      String?
  businessToken      String?
  gender             String?
  state              String?        @default("Lagos")
  lga                String?
  referredByCode     String?        // GCY-AFF-XXXXXX code used at signup (buyers only)
  Address            Address[]
  notifications      Notification[]
  buyerOrders        Order[]        @relation("BuyerRelation")
  ratings            Rating[]
  store              Store?
  needsPasswordChange Boolean        @default(false)
  blogs              Blog[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @default(now()) @updatedAt

  @@index([role])
  @@index([accountStatus])
  @@index([role, accountStatus])           // Admin: filter sellers/buyers by status
  @@index([createdAt])                     // Admin: sort users by registration date
  @@index([referredByCode])                // Affiliate: users referred by a code
  @@map("users")
}

model OrderItem {
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@id([orderId, productId])
  @@index([productId])
  @@index([orderId])
  @@map("OrderItem")
}

model Rating {
  id        String   @id @default(cuid())
  rating    Int
  review    String
  userId    String
  productId String
  orderId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, orderId])
  @@index([productId])
  @@map("Rating")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String
  street    String
  city      String
  state     String
  zip       String
  country   String
  phone     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Order     Order[]

  @@index([userId])
}

model Coupon {
  code        String   @id
  description String
  discount    Float
  forNewUser  Boolean
  forMember   Boolean  @default(false)
  isPublic    Boolean
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Store {
  id                 String    @id @default(cuid())
  userId             String    @unique
  name               String
  description        String
  username           String    @unique
  address            String
  status             String    @default("pending")
  isActive           Boolean   @default(false)
  logo               String
  email              String
  contact            String
  bankName           String?
  accountNumber      String?
  accountName        String?
  isVerified         Boolean   @default(false)
  isDirectorVerified Boolean   @default(false)
  nin                String?
  cac                String?
  walletBalance      Float     @default(0)
  rejectionReason    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  Order              Order[]
  Product            Product[]
  user               User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([username])
  @@index([isActive])                      // Shop: quick active store lookups
  @@index([status, isActive])              // Shop: WHERE status='approved' AND isActive=true
  @@index([createdAt])                     // Admin: sort stores by registration date
  @@map("Store")
}

model Product {
  id                  String      @id @default(cuid())
  name                String
  description         String
  mrp                 Float
  price               Float
  images              String[]
  category            String
  type                BatteryType @default(CAR_TRUCK_WET)
  brand               String?
  amps                Int         @default(0)
  condition           String      @default("SCRAP")
  pickupAddress       String
  collectionDateStart DateTime
  collectionDateEnd   DateTime
  collectionDates     String[]
  quantity            Int         @default(1)
  inStock             Boolean     @default(true)
  status              String      @default("pending")
  rejectionReason     String?
  storeId             String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  orderItems          OrderItem[]
  store               Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rating              Rating[]

  @@index([storeId])
  @@index([category])
  @@index([status])
  @@index([type])
  @@index([inStock])                         // Shop: quick stock availability check
  @@index([brand])                           // Shop: filter by battery brand
  @@index([condition])                       // Shop: filter by condition (SCRAP, USED, NEW)
  @@index([price])                           // Shop: price range sorting
  @@index([createdAt])                       // All: sort by newest
  @@index([storeId, status])                 // Seller dashboard: inventory by status (pending/approved/rejected)
  @@index([storeId, createdAt])              // Seller dashboard: sort inventory by date
  @@index([storeId, status, createdAt])      // Seller dashboard: compound for full inventory query
  @@index([status, inStock, createdAt])      // Shop/Landing: approved & in-stock products sorted by date
  @@index([status, inStock, storeId])        // Shop: approved products scoped to a store
  @@index([category, status, inStock])       // Shop: browse by category with availability filter
  @@map("Product")
}

model Order {
  id                String        @id
  transactionId     String?       @unique
  total             Float
  status            OrderStatus   @default(ORDER_PLACED)
  collectionStatus  PickupStatus  @default(PENDING)
  collectionToken   String?
  collectionDate    String?
  proposedDate      String?
  proposedBy        String?
  payoutStatus      String        @default("none")
  userId            String
  storeId           String
  addressId         String?
  isPaid            Boolean       @default(false)
  paymentMethod     PaymentMethod
  paymentSenderName String?
  paymentStatus     String        @default("pending")
  paymentReference  String? // Flutterwave tx_ref
  flutterwaveId     String? // Flutterwave transaction_id
  verificationCode  String?
  verificationStatus String       @default("PENDING")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  isCouponUsed      Boolean       @default(false)
  coupon            Json          @default("{}")
  buyerFee          Float         @default(0)
  payoutAmount      Float         @default(0)
  sellerFee         Float         @default(0)
  subtotal          Float         @default(0)
  address           Address?      @relation(fields: [addressId], references: [id])
  store             Store         @relation(fields: [storeId], references: [id])
  user              User          @relation("BuyerRelation", fields: [userId], references: [id])
  orderItems        OrderItem[]

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@index([isPaid])                          // Buyer dashboard: filter paid orders
  @@index([paymentStatus])
  @@index([payoutStatus])
  @@index([paymentReference])                // Flutterwave: lookup by payment ref
  @@index([transactionId])                   // Admin: quick order lookup by GCY-xxx ID
  @@index([userId, status, createdAt])       // Buyer dashboard: orders sorted by date
  @@index([userId, isPaid])                  // Buyer dashboard: only paid orders
  @@index([userId, isPaid, status])          // Buyer dashboard: paid orders by status
  @@index([storeId, status])                 // Seller orders: filter by status
  @@index([storeId, createdAt])              // Seller orders: sort by date
  @@index([storeId, payoutStatus])           // Admin payouts: pending payouts per store
  @@index([status, isPaid])                  // Admin: pending payment verification queue
  @@index([status, createdAt])              // Admin: order management sorted by date
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  status    String   @default("unread")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])                // Bell icon: COUNT unread per user
  @@index([userId, status, createdAt])     // Notification panel: unread first, sorted by date
  @@index([type])                          // Filter by notification type (ORDER, PAYMENT...)
  @@map("Notification")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
  SELLER
}

enum OrderStatus {
  ORDER_PLACED
  PAID
  APPROVED
  PROCESSING
  SHIPPED
  PICKED_UP
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  MANUAL_TRANSFER
  FLUTTERWAVE
}

enum BatteryType {
  CAR_TRUCK_WET
  INVERTER_DRY
  INVERTER_WET
}

enum PickupStatus {
  PENDING
  COLLECTED
  DISPUTED
  RESCHEDULE_REQUESTED
  RESCHEDULED
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String?  @default("general")
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
  @@map("Setting")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now())

  @@index([status])                        // Admin: count active subscribers
  @@index([createdAt])                     // Admin: sort by signup date
  @@map("NewsletterSubscriber")
}

model Blog {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  headlineImage String?
  content       String
  authorId      String
  status        String   @default("published")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([authorId])
  @@index([status])
  @@index([createdAt])                     // Blog: sort by newest
  @@index([status, createdAt])             // Blog feed: published posts sorted by date
  @@map("blogs")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])                         // Lookup reset tokens by email
  @@index([expiresAt])                     // Cleanup: find & delete expired tokens
  @@map("password_reset_tokens")
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])                      // Landing page: only fetch active partners
  @@index([order])                         // Landing page: sort partners by display order
  @@index([isActive, order])               // Landing page: active partners in order
  @@map("partners")
}


model ContactMessage {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  organization String?
  phone        String
  message      String
  status       String   @default("unread")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])                        // Admin inbox: filter unread messages
  @@index([createdAt])                     // Admin inbox: sort by received date
  @@index([status, createdAt])             // Admin inbox: unread messages sorted by date
  @@index([email])                         // Admin: lookup messages by sender email
  @@map("contact_messages")
}

model ManualVerification {
  id            String   @id @default(cuid())
  fullName      String
  accountNumber String
  bankCode      String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([bankCode])
  @@index([status])
  @@map("ManualVerification")
}

// ─── Affiliate System ───────────────────────────────────────────────────────

model Affiliate {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  phone           String   @unique
  password        String
  referralCode    String   @unique  // GCY-AFF-XXXXXX
  isEmailVerified Boolean  @default(false)
  isPhoneVerified Boolean  @default(false)
  status          String   @default("active")  // active | suspended
  walletBalance   Float    @default(0)
  totalEarned     Float    @default(0)
  bankName        String?
  accountNumber   String?
  accountName     String?
  verificationCode String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  earnings        AffiliateEarning[]
  payoutRequests  AffiliatePayoutRequest[]

  @@index([referralCode])
  @@index([status])
  @@index([createdAt])
  @@map("affiliates")
}

model AffiliateEarning {
  id          String   @id @default(cuid())
  affiliateId String
  orderId     String   @unique
  buyerId     String
  subtotal    Float
  buyerFee    Float
  commission  Float    // 50% of buyerFee = 2.5% of subtotal
  status      String   @default("pending")  // pending | paid
  createdAt   DateTime @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([status])
  @@index([orderId])
  @@map("affiliate_earnings")
}

model AffiliatePayoutRequest {
  id          String    @id @default(cuid())
  affiliateId String
  amount      Float
  bankName    String
  accountNumber String
  accountName String
  status      String    @default("pending")  // pending | approved | rejected
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([status])
  @@index([createdAt])
  @@map("affiliate_payout_requests")
}
